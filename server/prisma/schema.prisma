generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique @db.VarChar(32)
  displayName  String     @db.VarChar(64)
  passwordHash String
  avatarUrl    String?
  status       UserStatus @default(OFFLINE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  ownedServers     Server[]         @relation("ServerOwner")
  memberships      ServerMember[]
  messages         Message[]
  dmParticipations DMParticipant[]
  directMessages   DirectMessage[]

  @@index([username])
}

enum UserStatus {
  ONLINE
  IDLE
  DND
  OFFLINE
}

model Server {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(100)
  iconUrl    String?
  inviteCode String   @unique @default(uuid())
  ownerId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner    User           @relation("ServerOwner", fields: [ownerId], references: [id])
  channels Channel[]
  members  ServerMember[]

  @@index([inviteCode])
}

model ServerMember {
  id       String     @id @default(uuid())
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  userId   String
  serverId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([userId, serverId])
  @@index([serverId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

model Channel {
  id        String      @id @default(uuid())
  name      String      @db.VarChar(100)
  type      ChannelType
  position  Int         @default(0)
  serverId  String
  createdAt DateTime    @default(now())

  server   Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([serverId])
}

enum ChannelType {
  TEXT
  VOICE
}

model Message {
  id        String    @id @default(uuid())
  content   String    @db.Text
  userId    String
  channelId String
  editedAt  DateTime?
  createdAt DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
  @@index([userId])
}

model DMConversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  participants DMParticipant[]
  messages     DirectMessage[]
}

model DMParticipant {
  id             String @id @default(uuid())
  userId         String
  conversationId String

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation DMConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@index([conversationId])
}

model DirectMessage {
  id             String   @id @default(uuid())
  content        String   @db.Text
  senderId       String
  conversationId String
  createdAt      DateTime @default(now())

  sender       User           @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversation DMConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
